<element name="C8" library="InkTime_v5" package="GENERIC_0402" value="10uF" x="22" y="22"/>
<element name="C9" library="InkTime_v5" package="GENERIC_0402" value="100nF" x="23" y="22.5"/>

<!-- Caps for IC1 (Charger) -->
