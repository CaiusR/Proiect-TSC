<param name="dpGapFactor" value="2.5"/>
<description language="en">&lt;b&gt;JLCPCB design rules (2 layers)&lt;/b&gt;
&lt;ul&gt;
&lt;li&gt;Board thickness: 1mm&lt;/li&gt;
&lt;li&gt;Copper weight: 1oz (35um)&lt;/li&gt;
&lt;li&gt;Note: annular ring aren't minimal&lt;/li&gt;
&lt;/ul&gt;</description>
<param name="layerSetup" value="(1+2*15+16)"/>
<param name="mtCopper" value="0.035mm 0.035mm 0.035mm 0.035mm 0.035mm 0.035mm 0.035mm 0.035mm 0.035mm 0.035mm 0.035mm 0.035mm 0.035mm 0.035mm 0.035mm 0.035mm"/>
<param name="mtIsolate" value="1mm 0.15mm 0.2mm 0.15mm 0.2mm 0.15mm 0.2mm 0.15mm 0.2mm 0.15mm 0.2mm 0.15mm 0.2mm 0.15mm 0.2mm"/>
