<!-- L7: 4.7uH inductor near IC9 -->
<element name="L7" library="InkTime_v5" package="MLP2016SR47MT0S1_INDC2016X100N" value="4.7uH" x="25" y="22"/>

<!-- L1: 3.9nH near antenna matching -->
<element name="L1" library="InkTime_v5" package="NORDIC_NRF_2_RESC0201_L" value="3.9nH" x="28" y="18.5"/>

<!-- L2: 15nH near antenna matching -->
