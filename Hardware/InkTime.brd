<board>
<plain>
<!-- Board outline: circular ~36mm diameter on layer 20 (Dimension) -->
<!-- Center at (18, 18), radius = 18mm -->
<circle x="18" y="18" radius="18" width="0.1" layer="20"/>

<!-- PCB cutout under antenna area on layer 46 (Milling) -->
<!-- Antenna is at top-right edge (~30, 18), cutout slot behind it -->
<wire x1="28" y1="15.5" x2="33" y2="15.5" width="0.1" layer="46"/>
<wire x1="33" y1="15.5" x2="33" y2="20.5" width="0.1" layer="46"/>
<wire x1="33" y1="20.5" x2="28" y2="20.5" width="0.1" layer="46"/>
<wire x1="28" y1="20.5" x2="28" y2="15.5" width="0.1" layer="46"/>

<!-- Board info text -->
<text x="10" y="33" size="1.27" layer="25">InkTime Smartwatch</text>
<text x="10" y="1.5" size="0.8" layer="25">2-Layer 1.0mm PCB</text>
</plain>

<libraries>
<library name="InkTime_v5">
