<param name="tpViaShape" value="round"/>
<param name="PrefDir.1" value="a"/>
<param name="PrefDir.16" value="a"/>
</pass>
</autorouter>

<elements>
<!-- U1: nRF52840 - center of board -->
<element name="U1" library="InkTime_v5" package="NORDIC_NRF_4_AQFN50P700X700X85_HS-74N" value="nRF52840" x="18" y="18" locked="yes"/>

<!-- IC9: RT6160AWSC DCDC - near U1, upper right -->
<element name="IC9" library="InkTime_v5" package="RT6160AWSC_BGA15C40P3X5_140X230X60" value="RT6160AWSC" x="23" y="20"/>

<!-- IC1: BQ25180 charger - near USB connector (bottom) -->
<element name="IC1" library="InkTime_v5" package="BQ25180YBGR_BGA8C40P2X4_100X155X50" value="BQ25180YBGR" x="16" y="5.5"/>

<!-- IC3: BMA423 accelerometer - near center -->
<element name="IC3" library="InkTime_v5" package="BMA423_BMA423" value="BMA423" x="14" y="15"/>

<!-- U3: MAX17048 fuel gauge - near battery area -->
<element name="U3" library="InkTime_v5" package="ESP32_C6_LIBRARY_SON50P200X200X80-9N" value="MAX17048G+T10" x="12" y="10"/>

<!-- IC2: DRV2605 haptic - edge area lower left -->
<element name="IC2" library="InkTime_v5" package="DRV2605YZFR_BGA9C50P3X3_144X144X62" value="DRV2605YZFR" x="8" y="12"/>

<!-- ANT1: Antenna - right edge of PCB -->
<element name="ANT1" library="InkTime_v5" package="2450AT18B100E_ANTC3216X140N" value="2450AT18B100E" x="33" y="18"/>

<!-- J1: EPD connector - top edge -->
<element name="J1" library="InkTime_v5" package="503480-2400_5034802400" value="EPD_24P" x="18" y="33.5" rot="R180"/>

<!-- J4: USB-C - bottom edge -->
<element name="J4" library="InkTime_v5" package="KH-TYPE-C-16P_KINGHELM_KH-TYPE-C-16P" value="USB-C" x="18" y="2"/>

<!-- J2: SWD debug connector - accessible area, lower right -->
<element name="J2" library="InkTime_v5" package="TC2030-IDC_TC2030IDC" value="TC2030" x="25" y="8"/>

<!-- SW_UP: Button - left edge, top -->
<element name="SW_UP" library="InkTime_v5" package="2025-10-22_07-23-44_LIBRARY_SW_EVP-AKE31A_PAN" value="SW_UP" x="2" y="23" rot="R90"/>

<!-- SW_DN: Button - left edge, bottom -->
<element name="SW_DN" library="InkTime_v5" package="2025-10-22_07-23-44_LIBRARY_SW_EVP-AKE31A_PAN" value="SW_DN" x="2" y="13" rot="R90"/>

<!-- SW_ENT: Button - left edge, middle -->
<element name="SW_ENT" library="InkTime_v5" package="2025-10-22_07-23-44_LIBRARY_SW_EVP-AKE31A_PAN" value="SW_ENT" x="2" y="18" rot="R90"/>

<!-- X1: 32MHz crystal - close to U1 right side -->
<element name="X1" library="InkTime_v5" package="NORDIC_NRF_BT-XTAL_2016_N" value="32MHz" x="22.5" y="16.5"/>

<!-- X2: 32.768kHz crystal - close to U1 left side -->
