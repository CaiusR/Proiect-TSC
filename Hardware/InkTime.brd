<vertex x="29.0" y="1.2" curve="-20"/>
<vertex x="33.2" y="4.0" curve="-20"/>
<vertex x="35.2" y="10.5" curve="-20"/>
<vertex x="36.0" y="18.0" curve="-20"/>
<!-- Exclude antenna area from ground pour -->
<vertex x="35.2" y="22.0"/>
<vertex x="27.5" y="22.0"/>
<vertex x="27.5" y="14.0"/>
<vertex x="35.2" y="14.0"/>
<vertex x="35.2" y="14.0" curve="-20"/>
<vertex x="35.2" y="10.5"/>
</polygon>

<!-- Antenna keepout: tRestrict (layer 41) - no top copper under antenna -->
